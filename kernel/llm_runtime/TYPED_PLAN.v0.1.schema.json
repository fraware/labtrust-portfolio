{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/labtrust/kernel/llm_runtime/TYPED_PLAN.v0.1",
  "title": "TYPED_PLAN.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "plan_id",
    "steps"
  ],
  "properties": {
    "version": {
      "const": "0.1"
    },
    "plan_id": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "seq",
          "tool",
          "args",
          "validators"
        ],
        "properties": {
          "seq": {
            "type": "integer",
            "minimum": 0
          },
          "tool": {
            "type": "string"
          },
          "args": {
            "type": "object"
          },
          "validators": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
