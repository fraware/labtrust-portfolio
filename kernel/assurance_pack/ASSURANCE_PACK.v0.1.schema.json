{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/labtrust/kernel/assurance_pack/ASSURANCE_PACK.v0.1",
  "title": "ASSURANCE_PACK.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "system",
    "hazards",
    "controls",
    "evidence_map"
  ],
  "properties": {
    "version": {
      "const": "0.1"
    },
    "system": {
      "type": "object",
      "description": "System boundary + assumptions (placeholder)"
    },
    "hazards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "control_ids"],
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "control_ids": {"type": "array", "items": {"type": "string"}},
          "ponr_ids": {"type": "array", "items": {"type": "string"}, "description": "Optional PONR ids from lab profile covered by this hazard"}
        }
      },
      "description": "Hazard log (placeholder)"
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "evidence_artifact_types": {"type": "array", "items": {"type": "string"}}
        }
      },
      "description": "Invariants/controls (placeholder)"
    },
    "evidence_map": {
      "type": "object",
      "description": "Mapping hazards\u2192controls\u2192evidence types (placeholder)"
    }
  }
}
