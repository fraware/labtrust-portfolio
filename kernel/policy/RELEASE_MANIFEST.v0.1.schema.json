{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/labtrust/kernel/policy/RELEASE_MANIFEST.v0.1",
  "title": "RELEASE_MANIFEST.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "release_id",
    "created_at_utc",
    "kernel_version",
    "artifacts"
  ],
  "properties": {
    "version": {
      "const": "0.1"
    },
    "release_id": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "kernel_version": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
