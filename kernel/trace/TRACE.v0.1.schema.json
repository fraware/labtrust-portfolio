{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/labtrust/kernel/trace/TRACE.v0.1",
  "title": "TRACE.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "scenario_id",
    "seed",
    "start_time_utc",
    "events",
    "final_state_hash"
  ],
  "properties": {
    "version": {
      "const": "0.1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "seed": {
      "type": "integer"
    },
    "start_time_utc": {
      "type": "string",
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "seq",
          "ts",
          "type",
          "actor",
          "payload",
          "state_hash_after"
        ],
        "properties": {
          "seq": {
            "type": "integer",
            "minimum": 0
          },
          "ts": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "actor": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "id"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "agent",
                  "tool",
                  "system",
                  "human"
                ]
              },
              "id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "payload": {
            "type": "object"
          },
          "state_hash_after": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "final_state_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "metadata": {
      "type": "object"
    }
  }
}
